# Supabase — shared grid snapshots (see supabase/README.md)
# Run migration: supabase/migrations/20260330120000_scibo_grid_snapshots.sql (Dashboard SQL or supabase db push)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: default room if you omit ?room= in the URL (same value as in builder “Share room”)
# VITE_GRID_CLOUD_ROOM=demo-room

# Optional stream / embed (existing)
# VITE_STREAM_URL=
# VITE_STREAM_YOUTUBE_URL=

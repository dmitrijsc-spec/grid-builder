# Supabase (see supabase/README.md — run all migrations in order)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Prefer new publishable key; legacy anon also works:
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_SUPABASE_ANON_KEY=eyJ...

# Optional: default room if you omit ?room= in the URL (same value as in builder “Share room”)
# VITE_GRID_CLOUD_ROOM=demo-room

# Optional stream / embed (existing)
# VITE_STREAM_URL=
# VITE_STREAM_YOUTUBE_URL=
